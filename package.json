{
  "name": "ourwish",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "electron/main.mjs",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run client\"",
    "dev:server": "tsx server/index.ts",
    "dev:both": "concurrently \"npm run dev:server\" \"npm run client\"",
    "client": "vite",
    "web:build": "npm run build:web",
    "build:web": "vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "docker:build": "docker compose build",
    "docker:up": "docker compose up -d --build",
    "docker:logs": "docker compose logs -f --tail=200",
    "docker:down": "docker compose down",
    "icons:generate": "node scripts/generate-icons.mjs",
    "electron:start": "electron .",
    "electron:dev": "concurrently -k \"npm run dev:server\" \"npm run client\" \"wait-on tcp:5001 http://127.0.0.1:5175 && electron .\"",
    "electron:dist": "npm run build:web && npm run build:server && npm run icons:generate && electron-builder --mac"
  },
  "dependencies": {
    "axios": "^1.7.2",
    "bootstrap": "^5.3.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.21.1",
    "express-session": "^1.19.0",
    "jsdom": "^24.1.0",
    "react": "^19.2.0",
    "react-bootstrap": "^2.10.6",
    "react-dom": "^19.2.0",
    "sql.js": "^1.14.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/express-session": "^1.17.15",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/sql.js": "^1.4.9",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.1.2",
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "net.gwsapp.ourwish",
    "productName": "OurWish",
    "directories": {
      "buildResources": "build-resources",
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "build/server/**/*",
      "electron/**/*",
      "package.json"
    ],
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.productivity",
      "icon": "build-resources/icon.icns"
    }
  }
}
